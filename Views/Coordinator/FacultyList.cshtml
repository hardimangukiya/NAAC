@model IEnumerable<NAAC.Models.User>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Faculty Roster";
}

<div class="animate-fade-in p-2">
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">
        <div>
            <h2 class="fw-800 mb-0">Department Faculty</h2>
            <p class="text-secondary small">View and manage faculty assignments in your department</p>
        </div>
        <div class="input-group glass-panel border px-3 py-1" style="max-width: 350px;">
            <span class="input-group-text bg-transparent border-0 text-secondary"><i class="bi bi-search"></i></span>
            <input type="text" id="facultySearch" class="form-control bg-transparent border-0 text-dark small" placeholder="Search by name or email...">
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-panel p-5 border-0 shadow-lg text-center">
            <div class="display-1 text-primary mb-3 opacity-25"><i class="bi bi-people"></i></div>
            <h4 class="fw-bold">No Faculty Found</h4>
            <p class="text-secondary">There are no faculty members registered in your department yet.</p>
            <a asp-action="Dashboard" class="btn btn-primary rounded-pill px-4 mt-3">Return to Hub</a>
        </div>
    }
    else
    {
        <div class="glass-panel p-0 border-0 shadow-lg overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="facultyTable">
                    <thead>
                        <tr class="bg-light bg-opacity-50">
                            <th class="ps-4 py-3 border-0 small fw-bold text-uppercase text-secondary">Faculty Profile</th>
                            <th class="py-3 border-0 small fw-bold text-uppercase text-secondary">Contact Info</th>
                            <th class="py-3 border-0 small fw-bold text-uppercase text-secondary text-center">Joined Date</th>
                            <th class="py-3 border-0 small fw-bold text-uppercase text-secondary text-end pe-4">Status</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var faculty in Model)
                        {
                            <tr>
                                <td class="ps-4 py-4 align-middle">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-primary bg-opacity-10 text-primary fw-bold">
                                            @faculty.FullName.Substring(0, 1)
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@faculty.FullName</div>
                                            <div class="smaller text-secondary">@faculty.Role</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-4 align-middle">
                                    <div class="small fw-semibold text-dark">@faculty.Email</div>
                                    <div class="smaller text-secondary">@faculty.MobileNumber</div>
                                </td>
                                <td class="py-4 align-middle text-center">
                                    <div class="small text-dark">@faculty.CreatedAt.ToString("MMM dd, yyyy")</div>
                                </td>
                                <td class="text-end pe-4 py-4 align-middle">
                                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 small">
                                        Active
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }
    .smaller { font-size: 0.75rem; }
    #facultyTable tbody tr { transition: background-color 0.2s; cursor: pointer; }
    #facultyTable tbody tr:hover { background-color: rgba(0,0,0,0.02); }
</style>

@section Scripts {
    <script>
        document.getElementById('facultySearch').addEventListener('keyup', function() {
            let val = this.value.toLowerCase();
            let rows = document.querySelectorAll('#facultyTable tbody tr');
            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
            });
        });
    </script>
}
