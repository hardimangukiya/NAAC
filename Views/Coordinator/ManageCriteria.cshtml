@model IEnumerable<NAAC.Models.Criteria>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Structural Monitoring";
    var assignments = ViewBag.Assignments as List<NAAC.Models.CriteriaAssignment>;
}

<div class="animate-fade-in p-2 p-md-0">
    <!-- Premium Header -->
    <div class="d-flex justify-content-between align-items-end mb-5 pb-2 border-bottom border-white border-opacity-10 flex-wrap gap-4">
        <div>
            <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb smaller text-uppercase ls-1 fw-700 opacity-50 mb-0">
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-main">Coordinator</a></li>
                    <li class="breadcrumb-item active text-primary" aria-current="page">Framework Hub</li>
                </ol>
            </nav>
            <h1 class="display-6 fw-800 mb-0 tracking-tight text-gradient-primary">Structural Architecture</h1>
            <p class="text-secondary smaller mt-1 mb-0">Oversee institutional NAAC criteria and monitor departmental lead assignments.</p>
        </div>
        <div class="d-flex gap-3 pb-2">
            <div class="search-glass rounded-pill px-4 py-2 d-flex align-items-center bg-white bg-opacity-5 border border-white border-opacity-10">
                <i class="bi bi-search text-primary me-3"></i>
                <select id="criteriaDropdown" class="form-select bg-transparent border-0 text-main smaller shadow-none p-0 cursor-pointer" style="min-width: 250px;">
                    <option value="">Search All Frameworks...</option>
                    @foreach (var crit in Model)
                    {
                        <option value="@crit.Number">@crit.Number: @crit.Title</option>
                    }
                </select>
            </div>
            <button class="btn btn-premium-glow rounded-pill px-4 fw-bold border-0" data-bs-toggle="modal" data-bs-target="#addCriteriaModal">
                <i class="bi bi-plus-lg me-2"></i>New Framework
            </button>
        </div>
    </div>

    <div class="row g-5">
        <!-- Main Content Area -->
        <div class="col-lg-8">
            <div class="d-flex flex-column gap-3" id="criteriaList">
                @for (int i = 0; i < Model.Count(); i++)
                {
                    var crit = Model.ElementAt(i);
                    var assignment = assignments?.FirstOrDefault(a => a.CriteriaId == crit.Id);
                    <div class="premium-glass-card stagger-item" style="--item-index: @i" data-criteria-no="@crit.Number">
                        <div class="p-4" data-bs-toggle="collapse" data-bs-target="#tables-@crit.Id" role="button">
                            <div class="d-flex align-items-center gap-4">
                                <div class="crit-indicator">
                                    <span class="num text-white">@crit.Number</span>
                                    <span class="tag text-white">CR</span>
                                </div>
                                <div class="flex-grow-1">
                                    <h4 class="fw-800 mb-1 text-main">@crit.Title</h4>
                                    <div class="d-flex align-items-center gap-4 mt-2">
                                        <div class="d-flex align-items-center gap-2 smaller text-secondary">
                                            <i class="bi bi-diagram-3 text-primary"></i>
                                            <span class="fw-bold">@(crit.Tables?.Count ?? 0)</span> Data Streams
                                        </div>
                                        @if (assignment != null)
                                        {
                                            <div class="d-flex align-items-center gap-2 smaller text-success">
                                                <i class="bi bi-person-check-fill"></i>
                                                <span class="fw-bold text-uppercase ls-1">Lead: @assignment.Faculty?.FullName</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center gap-2 smaller text-danger opacity-75">
                                                <i class="bi bi-person-x"></i>
                                                <span class="fw-bold text-uppercase ls-1">Unassigned</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex flex-column gap-2" onclick="event.stopPropagation()">
                                    <button class="btn-action-glass text-primary" data-bs-toggle="modal" data-bs-target="#editCriteriaModal-@crit.Id">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button class="btn-action-glass text-danger" data-bs-toggle="modal" data-bs-target="#deleteCriteriaModal-@crit.Id">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Expanded Content -->
                        <div class="collapse" id="tables-@crit.Id">
                            <div class="p-4 pt-0">
                                <div class="bg-white bg-opacity-5 rounded-4 p-4 border border-white border-opacity-5 mt-3">
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <h6 class="text-primary smaller fw-800 text-uppercase ls-1 mb-0">Institutional Data Specifications</h6>
                                        <a asp-action="CriteriaDetails" asp-route-id="@crit.Id" class="btn btn-sm btn-primary rounded-pill px-4 shadow-lg border-0 fw-bold">
                                            Open Architecture Studio <i class="bi bi-arrow-right-short ms-1"></i>
                                        </a>
                                    </div>
                                    <div class="row g-3">
                                        @if (crit.Tables != null && crit.Tables.Any())
                                        {
                                            foreach (var table in crit.Tables.OrderBy(t => t.TableNumber))
                                            {
                                                <div class="col-md-6">
                                                    <div class="table-mini-card h-100">
                                                        <div class="d-flex align-items-center gap-3 flex-grow-1" style="min-width: 0;">
                                                            <div class="table-id-pill flex-shrink-0 text-white">@table.TableNumber</div>
                                                            <div class="flex-grow-1" style="min-width: 0;">
                                                                <div class="small fw-bold text-main lh-sm text-line-clamp-2">@table.Name</div>
                                                                <div class="smaller text-secondary opacity-50">@(table.Columns?.Count ?? 0) Schema Fields</div>
                                                            </div>
                                                        </div>
                                                        <a asp-action="CriteriaDetails" asp-route-id="@crit.Id" class="table-mini-arrow ms-2 flex-shrink-0"><i class="bi bi-chevron-right"></i></a>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="col-12 py-3 text-center opacity-30 text-secondary smaller italic">
                                                No table modules initialized for this framework.
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- System Stats Sidebar -->
        <div class="col-lg-4">
            <div class="d-flex flex-column gap-4 sticky-top" style="top: 2rem;">
                <div class="premium-glass-card p-5 border-0 shadow-2xl relative overflow-hidden bg-gradient-sidebar min-h-300">
                    <div class="glow-orb"></div>
                    <div class="relative-content">
                        <div class="stat-icon-large bg-primary bg-opacity-20 text-primary mb-4">
                            <i class="bi bi-activity"></i>
                        </div>
                        <h4 class="fw-800 text-main mb-2">System Health</h4>
                        <p class="text-secondary smaller opacity-75 mb-4">Real-time verification of institutional schema integrity and faculty assignment levels.</p>
                        
                        <div class="space-y-4 mb-5">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="smaller fw-bold text-secondary uppercase ls-1">Lead Coverage</span>
                                <span class="smaller fw-800 text-success">@((assignments?.Count ?? 0) * 100 / (Model.Count() > 0 ? Model.Count() : 1))%</span>
                            </div>
                            <div class="progress-premium">
                                <div class="bar bg-success" style="width: @((assignments?.Count ?? 0) * 100 / (Model.Count() > 0 ? Model.Count() : 1))%"></div>
                            </div>
                        </div>

                        <div class="d-grid pt-2">
                             <a href="#" class="btn btn-portal-glass py-3 fw-bold smaller text-main ls-1 text-uppercase">
                                 <i class="bi bi-shield-lock me-2"></i> Framework Lockdown
                             </a>
                        </div>
                    </div>
                </div>

                <!-- Small Info Cards -->
                <div class="glass-info-item stagger-item" style="--item-index: @(Model.Count() + 1)">
                    <div class="icon-box text-primary"><i class="bi bi-server"></i></div>
                    <div>
                        <div class="text-secondary smaller fw-bold ls-1 uppercase">Infrastructure</div>
                        <div class="text-main small fw-bold">Institutional Data Lake Active</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modals (Add/Edit/Delete) - Cleaned up -->
<div class="modal fade" id="addCriteriaModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal-glass border-0 shadow-2xl overflow-hidden p-4">
            <div class="modal-header border-0 pb-2">
                <h5 class="fw-800 text-main mb-0"><i class="bi bi-stack-overflow me-2 text-primary"></i>Define New Framework</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateCriteria" method="post">
                <div class="modal-body py-4">
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <label class="text-secondary smaller fw-bold mb-1 d-block">ID</label>
                            <input type="text" name="Number" class="glass-input" placeholder="e.g. 5" required>
                        </div>
                        <div class="col-md-9">
                            <label class="text-secondary smaller fw-bold mb-1 d-block">Title</label>
                            <input type="text" name="Title" class="glass-input" placeholder="e.g. Student Support & Progression" required>
                        </div>
                    </div>
                    <label class="text-secondary smaller fw-bold mb-1 d-block">Architectural Objective</label>
                    <textarea name="Description" class="glass-input" style="height: 100px" placeholder="Summary..."></textarea>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="submit" class="btn btn-primary rounded-pill w-100 py-3 fw-800 shadow-lg border-0">INITIATE FRAMEWORK</button>
                </div>
            </form>
        </div>
    </div>
</div>

@foreach (var crit in Model)
{
    <!-- Edit/Delete Modals (simplified for brevity, ensuring they follow the new style) -->
    <div class="modal fade" id="editCriteriaModal-@crit.Id" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content premium-modal-glass border-0 shadow-2xl p-4">
                <div class="modal-header border-0 pb-2">
                    <h5 class="fw-800 text-main mb-0">Modify Framework Metadata</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="EditCriteria" method="post">
                    <input type="hidden" name="Id" value="@crit.Id" />
                    <div class="modal-body py-4">
                         <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <label class="text-secondary smaller fw-bold mb-1 d-block">ID</label>
                                <input type="text" name="Number" value="@crit.Number" class="glass-input" required>
                            </div>
                            <div class="col-md-9">
                                <label class="text-secondary smaller fw-bold mb-1 d-block">Title</label>
                                <input type="text" name="Title" value="@crit.Title" class="glass-input" required>
                            </div>
                        </div>
                        <label class="text-secondary smaller fw-bold mb-1 d-block">Context</label>
                        <textarea name="Description" class="glass-input" style="height: 100px text-main">@crit.Description</textarea>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="submit" class="btn btn-primary rounded-pill w-100 py-3 fw-800 border-0 text-white">UPDATE METADATA</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteCriteriaModal-@crit.Id" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content premium-modal-glass border-0 shadow-2xl p-4 text-center">
                <div class="modal-body py-4">
                    <div class="text-danger mb-3 fs-1"><i class="bi bi-exclamation-octagon-fill"></i></div>
                    <h5 class="fw-800 text-main">Permanently Remove?</h5>
                    <p class="text-secondary smaller">All structural tables within <strong>@crit.Number</strong> will be lost forever.</p>
                    <form asp-action="DeleteCriteria" method="post">
                        <input type="hidden" name="id" value="@crit.Id" />
                        <div class="d-flex gap-2 mt-4">
                            <button type="button" class="btn btn-portal-glass flex-grow-1 text-main" data-bs-dismiss="modal">KEEP</button>
                            <button type="submit" class="btn btn-danger flex-grow-1 fw-bold rounded-pill text-white">REMOVE</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<style>
    :root {
        --text-main: #020617;
        --text-secondary: #64748b;
        --glass-bg: rgba(255, 255, 255, 0.6);
        --glass-border: rgba(0, 0, 0, 0.08);
        --accent-primary: #6366f1;
        --accent-secondary: #a855f7;
    }

    [data-theme="dark"] {
        --text-main: #f8fafc;
        --text-secondary: #94a3b8;
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.08);
    }

    .text-main { color: var(--text-main) !important; }
    .text-secondary { color: var(--text-secondary) !important; }

    .fw-800 { font-weight: 800; }
    .ls-1 { letter-spacing: 1px; }
    .tracking-tight { letter-spacing: -1px; }
    .text-gradient-primary {
        background: linear-gradient(135deg, var(--text-main) 30%, #6366f1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .premium-glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        overflow: hidden;
    }
    .premium-glass-card:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(99, 102, 241, 0.3);
        transform: translateY(-5px);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .crit-indicator {
        width: 60px; height: 60px;
        background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
        border-radius: 18px;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        flex-shrink: 0; box-shadow: 0 10px 20px -5px rgba(99, 102, 241, 0.4);
    }
    .crit-indicator .num { color: white; font-size: 1.4rem; font-weight: 800; line-height: 1; }
    .crit-indicator .tag { color: white; font-size: 0.6rem; font-weight: 800; opacity: 0.6; text-uppercase; margin-top: 2px; }

    .btn-action-glass {
        width: 36px; height: 36px; border-radius: 10px; border: 1px solid var(--glass-border);
        background: transparent; display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
    }
    .btn-action-glass:hover { background: rgba(255, 255, 255, 0.1); transform: scale(1.1); }

    .table-mini-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 12px 16px;
        display: flex; align-items: center; justify-content: space-between;
        transition: all 0.2s;
        overflow: hidden;
    }
    .text-line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        word-break: break-word;
    }
    .table-mini-card:hover { background: rgba(255, 255, 255, 0.08); transform: scale(1.02); }
    .table-id-pill { background: var(--accent-primary); color: white; padding: 2px 8px; border-radius: 8px; font-size: 0.7rem; font-weight: 800; }
    .table-mini-arrow { color: rgba(255,255,255,0.3); font-size: 0.8rem; }

    /* Sidebar Styles */
    .bg-gradient-sidebar { background: linear-gradient(165deg, rgba(99, 102, 241, 0.1) 0%, rgba(15, 23, 42, 0) 100%); }
    .stat-icon-large { width: 56px; height: 56px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .glow-orb {
        position: absolute; top: -10%; right: -10%; width: 200px; height: 200px;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
        pointer-events: none;
    }
    .relative-content { position: relative; z-index: 2; }

    .progress-premium { width: 100%; height: 8px; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden; }
    .progress-premium .bar { height: 100%; transition: width 1s ease-in-out; }

    .btn-portal-glass {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        transition: all 0.3s;
        text-decoration: none;
        text-align: center;
    }
    .btn-portal-glass:hover { background: rgba(255, 255, 255, 0.1); border-color: white; }

    .glass-info-item {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 16px 20px;
        display: flex; align-items: center; gap: 16px;
    }
    .icon-box { width: 40px; height: 40px; border-radius: 10px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; }

    .btn-premium-glow {
        background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
        color: white;
        box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.5);
        transition: all 0.3s;
    }
    .btn-premium-glow:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -5px rgba(99, 102, 241, 0.6);
        color: white;
    }

    .glass-input {
        width: 100%; padding: 12px 16px; background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border); border-radius: 14px; color: var(--text-main);
        transition: all 0.2s;
    }
    [data-theme="dark"] .glass-input { background: rgba(255, 255, 255, 0.03); }
    .glass-input:focus { background: rgba(255, 255, 255, 0.1); border-color: var(--accent-primary); outline: none; }

    .premium-modal-glass {
        background: var(--bg-main, #fff);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border) !important;
        border-radius: 28px !important;
    }
    [data-theme="dark"] .premium-modal-glass { background: rgba(15, 23, 42, 0.95); }

    /* Animations */
    .stagger-item {
        opacity: 0; transform: translateY(20px);
        animation: staggerFadeIn 0.6s ease forwards;
        animation-delay: calc(var(--item-index) * 0.1s);
    }
    @@keyframes staggerFadeIn { to { opacity: 1; transform: translateY(0); } }

    /* Override standard bootstrap breadcrumb dot */
    .breadcrumb-item + .breadcrumb-item::before { color: rgba(255,255,255,0.2) !important; }
</style>

@section Scripts {
    <script>
        document.getElementById('criteriaDropdown').addEventListener('change', function() {
            let val = this.value.toLowerCase().trim();
            let cards = document.querySelectorAll('#criteriaList > .premium-glass-card');
            
            cards.forEach(card => {
                let critNo = card.getAttribute('data-criteria-no').toLowerCase().trim();
                if (val === "" || critNo === val) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    </script>
}
