@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Digital Archive";
}

<div class="animate-fade-in p-2">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-800 mb-0">Document Repository</h2>
            <p class="text-secondary small">Centralized vault for all NAAC supporting documentation</p>
        </div>
        <div class="dropdown">
            <button class="btn glass-panel border-0 dropdown-toggle px-4 shadow-sm fw-bold" type="button" data-bs-toggle="dropdown">
                Criteria 5
            </button>
            <ul class="dropdown-menu glass-panel border-0 shadow-lg p-2">
                <li><a class="dropdown-item rounded-2" href="#">Criteria 3</a></li>
                <li><a class="dropdown-item rounded-2" href="#">Criteria 6</a></li>
            </ul>
        </div>
    </div>

    <div class="glass-panel p-5 border-0 shadow-lg h-100 text-center">
        <div class="display-3 text-warning opacity-25 mb-4"><i class="bi bi-folder-fill"></i></div>
        <h4 class="fw-bold text-dark">Repository Active</h4>
        <p class="text-secondary">Explore uploaded PDF, Excel, and Image files for the selected criteria.</p>
        <hr class="my-5 opacity-25" />
        <div class="row g-3">
            <div class="col-md-3">
                <div class="glass-panel p-3 border-secondary border-opacity-10">
                    <i class="bi bi-file-earmark-pdf text-danger fs-3"></i>
                    <div class="smaller fw-bold mt-2">Policy_2024.pdf</div>
                </div>
            </div>
            <div class="col-md-3 text-secondary d-flex align-items-center justify-content-center border border-dashed rounded-3">
                <div class="smaller">+ Add File</div>
            </div>
        </div>
    </div>
</div>
