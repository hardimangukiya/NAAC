@model IEnumerable<NAAC.Models.CriteriaAssignment>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "My Assigned Criteria";
}

<div class="animate-fade-in px-2 px-md-0">
    <div class="mb-5">
        <h2 class="fw-800 mb-0">Accreditation Portfolio</h2>
        <p class="text-secondary small">Comprehensive overview of your assigned documentation benchmarks and reporting status</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="glass-panel p-4 h-100 border-0 shadow-sm hover-up transition-300">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 rounded-pill fw-bold">Criterion @item.Criteria?.Number</span>
                            <div class="smaller text-secondary">
                                <i class="bi bi-calendar-check me-1"></i> @item.AssignedDate.ToString("MMM yyyy")
                            </div>
                        </div>
                        <h5 class="fw-bold mb-3">@item.Criteria?.Title</h5>
                        <p class="smaller text-secondary mb-4 line-clamp-3">@item.Criteria?.Description</p>
                        
                        <div class="d-flex gap-2">
                            <a asp-action="DataEntry" asp-route-criteriaId="@item.CriteriaId" class="btn btn-premium-primary btn-sm flex-grow-1 py-2 rounded-3">
                                <i class="bi bi-pencil-square me-2"></i> Enter Data
                            </a>
                            <a asp-action="MyTables" asp-route-criteriaId="@item.CriteriaId" class="btn btn-action" title="View Tables">
                                <i class="bi bi-table"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="glass-panel p-5 text-center shadow-sm">
                    <div class="opacity-25 mb-3"><i class="bi bi-journal-x fs-1"></i></div>
                    <h5 class="text-secondary">No criteria assigned yet</h5>
                    <p class="smaller text-muted">Please contact your HOD or Coordinator if you believe this is an error.</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
