@{
    ViewData["Title"] = "Portal Login";
}

<div class="auth-container">
    <div class="container">
        <div class="glass-panel auth-form-card animate-fade-in position-relative">
            <!-- Loading Spinner -->
            <div class="spinner-container" id="loginLoader">
                <div class="spinner-border-custom"></div>
            </div>

            <div id="login-form-content">
                <div class="text-center mb-5">
                    <i class="bi bi-person-lock text-primary" style="font-size: 3rem;"></i>
                    <h2 class="mt-3">System Login</h2>
                    <p class="text-secondary">Enter your credentials to access your NAAC dashboard</p>
                </div>

                <!-- Error Message Alert -->
                <div id="loginError" class="alert alert-danger mb-4 small" style="display:none;">
                    <i class="bi bi-exclamation-triangle me-2"></i> <span id="errorText"></span>
                </div>

                <!-- Step 1: Standard Password Login -->
                <div id="password-login-section">
                    <form id="loginForm" asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="form-floating-custom">
                            <label>Email Address</label>
                            <input type="email" name="email" class="form-control-custom" placeholder="abc@gmail.com" required />
                        </div>

                        <div class="form-floating-custom">
                            <label>Password</label>
                            <input type="password" name="password" id="loginPassword" class="form-control-custom" placeholder="••••••••" required />
                            <i class="bi bi-eye password-toggle" id="toggleLoginPassword"></i>
                        </div>

                        <div class="login-options-row">
                            <label class="form-check-custom">
                                <input type="checkbox" name="rememberMe" class="form-check-input-custom" value="true" />
                                <span>Remember Me</span>
                            </label>
                            <a asp-action="ForgotPassword" class="text-primary text-decoration-none fw-medium">Forgot Password?</a>
                        </div>

                        <button type="submit" class="btn-portal w-100 py-3">
                            Sign In <i class="bi bi-box-arrow-in-right ms-1"></i>
                        </button>
                    </form>

                    <div class="divider">OR</div>

                    <button type="button" id="showOtpLogin" class="btn w-100 py-2 text-secondary fw-medium" style="background: var(--secondary-color); border: 1px solid var(--glass-border); border-radius: 0.75rem;">
                        <i class="bi bi-phone me-2"></i> Login with OTP
                    </button>
                </div>

                <!-- Step 2: Request OTP (Hidden by default) -->
                <div id="login-otp-section" style="display:none;">
                    <form id="otpLoginForm" asp-action="LoginWithOTP" method="post">
                        <div class="form-floating-custom">
                            <label>Registered Email Address</label>
                            <input type="email" id="otpEmailInput" name="email" class="form-control-custom" placeholder="abc@gmail.com" required />
                        </div>
                        
                        <button type="submit" class="btn-portal w-100 py-3 mb-4">
                            Send Login OTP <i class="bi bi-send ms-1"></i>
                        </button>

                        <button type="button" class="backToPassword btn w-100 text-secondary small">
                            <i class="bi bi-arrow-left me-1"></i> Back to Password Login
                        </button>
                    </form>
                </div>

                <!-- Step 3: Verify OTP (Hidden by default) -->
                <div id="login-verify-otp-section" style="display:none;">
                    <form id="verifyOtpLoginForm" asp-action="VerifyLoginOTP" method="post">
                        <input type="hidden" id="verifyOtpEmailHidden" name="email" />
                        
                        <div class="text-center mb-4">
                            <i class="bi bi-shield-lock text-success" style="font-size: 2.5rem;"></i>
                            <p class="small text-secondary mt-2">Enter the 6-digit code sent to your email</p>
                        </div>

                        <div class="form-floating-custom">
                            <label>Verification Code</label>
                            <input type="text" name="otp" class="form-control-custom text-center fw-bold fs-4" placeholder="000000" maxlength="6" required />
                        </div>
                        
                        <button type="submit" class="btn-portal w-100 py-3 mb-4">
                            Verify & Login <i class="bi bi-check-circle ms-1"></i>
                        </button>

                        <button type="button" id="resendLoginOtp" class="btn w-100 text-primary small mb-2">
                            Resend Code
                        </button>

                        <button type="button" class="backToPassword btn w-100 text-secondary small">
                            <i class="bi bi-arrow-left me-1"></i> Back to Login
                        </button>
                    </form>
                </div>

                <!-- Footer Links -->
                <div class="auth-footer-links mt-5 pt-4">
                    <a asp-action="Register" class="text-secondary text-decoration-none">
                        Not registered yet? <span class="text-primary fw-bold">Register as HOD</span>
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="text-secondary text-decoration-none">
                        Home Page <i class="bi bi-house-door ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/login-logic.js"></script>
}
