@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-container">
    <div class="container">
        <div class="glass-panel auth-form-card animate-fade-in relative overflow-hidden" style="max-width: 500px;">
            <!-- Loading Spinner Container -->
            <div id="auth-loader" class="spinner-container">
                <div class="spinner-border-custom"></div>
            </div>

            <div id="form-body">
                <div class="text-center mb-5">
                    <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
                    <h2 class="mt-3">Reset Password</h2>
                    <p class="text-secondary small">Follow the steps to recover your account</p>
                </div>

                <!-- ALERT BOX -->
                <div id="alert-box" class="alert d-none mb-4 small" role="alert"></div>

                <!-- STEP 1: EMAIL ENTRY -->
                <div id="step-1">
                    <form id="form-step-1">
                        <div class="form-floating-custom">
                            <label>Registered Email Address</label>
                            <input type="email" id="email-input" class="form-control-custom" placeholder="abc@gmail.com" required />
                        </div>
                        <button type="submit" class="btn-portal w-100 py-3 mt-3">
                            Send Reset Code <i class="bi bi-send ms-2"></i>
                        </button>
                    </form>
                </div>

                <!-- STEP 2: OTP VERIFICATION -->
                <div id="step-2" class="d-none">
                    <div class="text-center mb-4">
                        <p class="text-secondary small">Please enter the 6-digit code sent to your email.</p>
                        <div class="badge bg-light text-primary py-2 px-3 fw-bold fs-6 border" id="otp-timer">02:00</div>
                    </div>

                    <form id="form-step-2">
                        <div class="otp-inputs mb-4">
                            <input type="text" class="otp-box-reset" maxlength="1" required />
                            <input type="text" class="otp-box-reset" maxlength="1" required />
                            <input type="text" class="otp-box-reset" maxlength="1" required />
                            <input type="text" class="otp-box-reset" maxlength="1" required />
                            <input type="text" class="otp-box-reset" maxlength="1" required />
                            <input type="text" class="otp-box-reset" maxlength="1" required />
                        </div>
                        
                        <button type="submit" class="btn-portal w-100 py-3">
                            Verify Code <i class="bi bi-shield-check ms-2"></i>
                        </button>

                        <div class="text-center mt-4">
                            <button type="button" id="resend-otp" class="btn btn-link text-decoration-none text-secondary small p-0 disabled">
                                Didn't receive code? <span class="text-primary fw-bold">Resend</span>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- STEP 3: PASSWORD RESET -->
                <div id="step-3" class="d-none">
                    <form id="form-step-3">
                        <div class="form-floating-custom mb-4">
                            <label>New Password</label>
                            <div class="position-relative">
                                <input type="password" id="new-password" class="form-control-custom pe-5" placeholder="Min 8 characters" required />
                                <i class="bi bi-eye password-toggle-reset" onclick="togglePass('new-password', this)"></i>
                            </div>
                            <div class="password-rules mt-2 smaller text-secondary">
                                <i class="bi bi-info-circle me-1"></i> Min 8 chars, 1 uppercase, 1 number
                            </div>
                        </div>

                        <div class="form-floating-custom mb-4">
                            <label>Confirm Password</label>
                            <div class="position-relative">
                                <input type="password" id="confirm-password" class="form-control-custom pe-5" placeholder="Repeat new password" required />
                                <i class="bi bi-eye password-toggle-reset" onclick="togglePass('confirm-password', this)"></i>
                            </div>
                        </div>

                        <button type="submit" class="btn-portal w-100 py-3 mt-2">
                            Update Password <i class="bi bi-check-circle ms-2"></i>
                        </button>
                    </form>
                </div>

                <!-- FOOTER NAVIGATION -->
                <div class="auth-footer-links mt-5 pt-4 border-top">
                    <a asp-action="Login" class="text-secondary text-decoration-none">
                        <i class="bi bi-arrow-left me-1"></i> Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .otp-box-reset {
        width: 3.5rem;
        height: 4rem;
        text-align: center;
        font-size: 1.5rem;
        font-weight: 700;
        border: 2px solid var(--glass-border);
        border-radius: 0.75rem;
        background: var(--input-bg);
        color: var(--text-primary);
        transition: var(--transition-smooth);
    }
    .otp-box-reset:focus {
        outline: none;
        border-color: var(--accent-color);
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
    }
    .password-toggle-reset {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: var(--text-secondary);
        z-index: 10;
        font-size: 1.2rem;
    }
    .smaller { font-size: 0.75rem; }
</style>

@section Scripts {
    <script src="~/js/forgot-password.js"></script>
    <script>
        function togglePass(inputId, icon) {
            const input = document.getElementById(inputId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            }
        }
    </script>
}
