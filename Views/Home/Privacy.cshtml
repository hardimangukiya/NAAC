@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="auth-container">
    <div class="container px-4">
        <div class="glass-panel p-5 animate-fade-in">
            <div class="text-center mb-5">
                <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
                <h1 class="hero-title mt-3">Privacy Policy</h1>
                <p class="text-secondary">Effective Date: April 2026</p>
            </div>

            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="mb-5">
                        <h3 class="mb-3 text-primary">1. 📥 Information We Collect</h3>
                        <p class="text-secondary">We may collect the following information:</p>
                        <ul class="text-secondary">
                            <li>Name, email address, and contact details</li>
                            <li>Department and institutional information</li>
                            <li>User login credentials (securely stored)</li>
                            <li>Data entered by users (student records, NAAC criteria data, documents)</li>
                        </ul>
                    </div>

                    <div class="mb-5">
                        <h3 class="mb-3 text-primary">2. 🎯 Purpose of Data Collection</h3>
                        <p class="text-secondary">The collected data is used to:</p>
                        <ul class="text-secondary">
                            <li>Manage NAAC-related records and documentation</li>
                            <li>Provide role-based access to users (HOD, Admin, Faculty, NAAC Coordinator)</li>
                            <li>Generate reports for institutional and accreditation purposes</li>
                            <li>Improve system functionality and performance</li>
                        </ul>
                    </div>

                    <div class="mb-5">
                        <h3 class="mb-3 text-primary">3. 🔒 Data Security</h3>
                        <p class="text-secondary">We ensure that:</p>
                        <ul class="text-secondary">
                            <li>User passwords are securely encrypted</li>
                            <li>Access is restricted based on user roles</li>
                            <li>Data is protected from unauthorized access or misuse</li>
                        </ul>
                    </div>

                    <div class="mb-5">
                        <h3 class="mb-3 text-primary">4. 🔄 Data Sharing</h3>
                        <p class="text-secondary">We do not share personal data with third parties.</p>
                    </div>

                    <div class="mb-5">
                        <h3 class="mb-3 text-primary">5. 🗂️ Data Storage</h3>
                        <p class="text-secondary">
                            All data is stored securely in the system database. Documents uploaded are used only for 
                            NAAC and internal reporting.
                        </p>
                    </div>

                    <div class="mb-5">
                        <h3 class="mb-3 text-primary">6. 👤 User Responsibility</h3>
                        <p class="text-secondary">Users are responsible for:</p>
                        <ul class="text-secondary">
                            <li>Maintaining confidentiality of login credentials</li>
                            <li>Entering accurate and valid data</li>
                        </ul>
                    </div>

                    <div class="mb-5">
                        <h3 class="mb-3 text-primary">7. 🔄 Updates to Policy</h3>
                        <p class="text-secondary">
                            This policy may be updated from time to time. Users will be notified of significant changes.
                        </p>
                    </div>


                    <div class="text-center mt-5 pt-4 border-top">
                        <p class="text-secondary small">For any privacy-related inquiries, please contact your System Coordinator.</p>
                        <a asp-action="Index" class="btn-portal px-5 py-2 mt-3">Back to Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
