@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Overview Hub";
}

<div class="animate-fade-in">
    <!-- Quick Stats Row -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="glass-panel p-4 h-100 stat-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="text-secondary small text-uppercase fw-bold ls-1">Department Roster</div>
                    <i class="bi bi-people text-primary fs-4"></i>
                </div>
                <div class="h1 fw-bold mb-1">@ViewBag.TotalUsers</div>
                <div class="small text-secondary">Registered users in system</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel p-4 h-100 stat-card" style="border-left-color: #22c55e;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="text-secondary small text-uppercase fw-bold ls-1">Active Faculty</div>
                    <i class="bi bi-person-workspace text-success fs-4"></i>
                </div>
                <div class="h1 fw-bold mb-1">@ViewBag.TotalFaculty</div>
                <div class="small text-secondary">Participating in criteria</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel p-4 h-100 stat-card" style="border-left-color: #eab308;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="text-secondary small text-uppercase fw-bold ls-1">Criteria Assigned</div>
                    <i class="bi bi-diagram-3 text-warning fs-4"></i>
                </div>
                <div class="h1 fw-bold mb-1">@ViewBag.AssignedCriteria</div>
                <div class="small text-secondary">Tasks currently mapped</div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-panel p-5 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="mb-0">Accreditation Progress</h3>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            Filter: All Criteria
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#">Criteria 5</a></li>
                            <li><a class="dropdown-item" href="#">Criteria 6</a></li>
                        </ul>
                    </div>
                </div>
                <div class="progress-item mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-medium">Criteria 5: Student Support</span>
                        <span class="small text-secondary">42% Complete</span>
                    </div>
                    <div class="progress" style="height: 10px; border-radius: 5px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 42%"></div>
                    </div>
                </div>
                <div class="progress-item mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-medium">Criteria 6: Governance</span>
                        <span class="small text-secondary">28% Complete</span>
                    </div>
                    <div class="progress" style="height: 10px; border-radius: 5px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 28%"></div>
                    </div>
                </div>
                <hr class="my-5 border-secondary border-opacity-10">
                <div class="text-center">
                    <p class="text-secondary mb-4">Ready to generate the monthly compliance snapshot?</p>
                    <a asp-action="Reports" class="btn-portal px-5">Generate Report Center</a>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="glass-panel p-5 h-100">
                <h4 class="mb-4">Authority Shortcuts</h4>
                <div class="list-group list-group-flush bg-transparent">
                    <a asp-action="ManageUsers" class="list-group-item list-group-item-action bg-transparent border-secondary border-opacity-10 px-0 py-3 d-flex align-items-center gap-3">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-plus-lg"></i>
                        </div>
                        <div>
                            <div class="fw-bold">Manage Users</div>
                            <div class="smaller text-secondary">Add or remove staff access</div>
                        </div>
                    </a>
                    <a asp-action="CriteriaAssignment" class="list-group-item list-group-item-action bg-transparent border-secondary border-opacity-10 px-0 py-3 d-flex align-items-center gap-3">
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="bi bi-signpost-split"></i>
                        </div>
                        <div>
                            <div class="fw-bold">Criteria Mapping</div>
                            <div class="smaller text-secondary">Assign tasks to faculty</div>
                        </div>
                    </a>
                    <a asp-action="Approvals" class="list-group-item list-group-item-action bg-transparent border-0 px-0 py-3 d-flex align-items-center gap-3">
                        <div class="icon-circle bg-warning bg-opacity-10 text-warning">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <div>
                            <div class="fw-bold">Verify Data</div>
                            <div class="smaller text-secondary">Approve pending uploads</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .icon-circle {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .smaller { font-size: 0.8rem; }
</style>
