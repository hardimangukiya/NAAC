@model IEnumerable<NAAC.Models.DataRecord>
@using NAAC.Models
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Finalized Records";
    var tableList = ViewBag.TableList as List<NAACTable> ?? new List<NAACTable>();
    var totalCount = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : 0;
    var selectedYear = ViewBag.SelectedYear != null ? ViewBag.SelectedYear.ToString() : "";
    var tableFilter = ViewBag.TableFilter != null ? ViewBag.TableFilter.ToString() : "";
}

<div class="animate-fade-in px-2 px-md-0">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-start mb-5 flex-wrap gap-3">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <a asp-action="Dashboard" class="text-secondary small text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i> Dashboard
                </a>
            </div>
            <!-- <h2 class="fw-800 mb-0">Finalized Records</h2>
            <p class="text-secondary small">All HOD-approved and audit-ready NAAC documentation</p>
         --></div>
        <div class="badge py-3 px-4 rounded-pill border fw-bold d-flex align-items-center gap-2"
             style="background: rgba(34, 197, 94, 0.1); border-color: rgba(34, 197, 94, 0.3) !important; color: #16a34a; font-size: 0.9rem;">
            <i class="bi bi-patch-check-fill"></i>
            @totalCount Finalized Record@(totalCount != 1 ? "s" : "")
        </div>
    </div>

    <!-- Filters Bar -->
    <div class="glass-panel p-4 mb-5 border-0 shadow-sm d-flex align-items-center gap-4 flex-wrap"
         style="position: relative; z-index: 100;">
        <!-- Year Filter -->
        <div class="dropdown">
            <button class="btn rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium"
                    type="button" data-bs-toggle="dropdown" aria-expanded="false"
                    style="background: var(--card-bg); border: 1px solid var(--glass-border); color: var(--text-primary); min-width: 150px;">
                <i class="bi bi-calendar3 text-primary"></i>
                <span style="color: var(--text-primary);">@ViewBag.SelectedYear</span>
                <i class="bi bi-chevron-down ms-1 small" style="color: var(--text-secondary);"></i>
            </button>
            <ul class="dropdown-menu shadow border-0 mt-1 rounded-3 p-2"
                style="z-index:9999; min-width:200px; background: var(--card-bg); border: 1px solid var(--glass-border) !important;">
                @foreach (var ay in (List<string>)ViewBag.AcademicYears)
                {
                    <li>
                        <a class="dropdown-item rounded-2 mb-1 @(selectedYear == ay ? "active" : "")"
                           href="?year=@ay&tableFilter=@tableFilter"
                           style="color: var(--text-primary);">@ay</a>
                    </li>
                }
            </ul>
        </div>

        <!-- Table Filter Dropdown -->
        <div class="dropdown">
            <button class="btn rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium"
                    type="button" data-bs-toggle="dropdown" aria-expanded="false"
                    style="background: var(--card-bg); border: 1px solid var(--glass-border); color: var(--text-primary); min-width: 210px;">
                <i class="bi bi-funnel-fill text-primary"></i>
                <span style="color: var(--text-primary);">
                    @if (!string.IsNullOrEmpty(tableFilter))
                    {
                        var selectedTable = tableList.FirstOrDefault(t => t.Id.ToString() == tableFilter);
                        @(selectedTable != null ? $"Table {selectedTable.TableNumber}" : "Filter by Table")
                    }
                    else { <text>Filter by Table</text> }
                </span>
                <i class="bi bi-chevron-down ms-1 small" style="color: var(--text-secondary);"></i>
            </button>
            <ul class="dropdown-menu shadow border-0 mt-1 rounded-3 p-2"
                style="z-index:9999; min-width:320px; max-height:380px; overflow-y:auto; background: var(--card-bg); border: 1px solid var(--glass-border) !important;">
                <li>
                    <a class="dropdown-item rounded-2 mb-1 @(string.IsNullOrEmpty(tableFilter) ? "active" : "")"
                       href="?year=@selectedYear"
                       style="color: var(--text-primary);">
                        <i class="bi bi-grid-3x3-gap me-2"></i> All Tables
                    </a>
                </li>
                <li><hr class="dropdown-divider my-1 opacity-25"></li>
                @foreach (var t in tableList)
                {
                    <li>
                        <a class="dropdown-item rounded-2 mb-1 @(tableFilter == t.Id.ToString() ? "active" : "")"
                           href="?year=@selectedYear&tableFilter=@t.Id"
                           style="color: var(--text-primary);">
                            <span class="badge bg-primary bg-opacity-10 text-primary me-2 small">@t.TableNumber</span>
                            @(t.Name.Length > 38 ? t.Name.Substring(0, 35) + "..." : t.Name)
                        </a>
                    </li>
                }
            </ul>
        </div>

        @if (!string.IsNullOrEmpty(tableFilter) || selectedYear != ((List<string>)ViewBag.AcademicYears)[0])
        {
            <a href="?year=@((List<string>)ViewBag.AcademicYears)[0]" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                <i class="bi bi-x-circle me-1"></i> Clear Filters
            </a>
        }

        <div class="ms-auto small text-secondary fw-medium">
            <i class="bi bi-info-circle me-1"></i> Showing @(Model?.Count() ?? 0) of @totalCount records
        </div>
    </div>

    <!-- Records List -->
    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var record in Model)
            {
                var rowData = new Dictionary<string, string>();
                try { rowData = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(record.JsonData ?? "{}") ?? new Dictionary<string, string>(); } catch { }

                <div class="col-12">
                    <div class="glass-panel p-0 overflow-hidden border-0 shadow-lg animate-fade-in">
                        <!-- Card Header -->
                        <div class="p-3 px-4 d-flex justify-content-between align-items-center border-bottom border-secondary border-opacity-10"
                             style="background: rgba(34, 197, 94, 0.06);">
                            <div class="d-flex align-items-center gap-3">
                                <div class="d-flex align-items-center justify-content-center rounded-circle bg-success text-white fw-bold"
                                     style="width: 34px; height: 34px; font-size: 0.8rem;">
                                    @((record.Faculty?.FullName ?? "F").Substring(0, 1).ToUpper())
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-0">@(record.Faculty?.FullName ?? "Unknown Faculty")</h6>
                                    <span class="smaller text-secondary">
                                        Verified on @(record.UpdatedAt.HasValue ? record.UpdatedAt.Value.ToString("MMM dd, yyyy HH:mm") : record.CreatedAt.ToString("MMM dd, yyyy"))
                                    </span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="text-end d-none d-md-block">
                                    <span class="badge bg-success bg-opacity-10 text-success mb-1">Table @(record.Table?.TableNumber ?? "N/A")</span>
                                    <div class="smaller fw-bold text-dark">@(record.Table?.Name ?? "–")</div>
                                    <div class="smaller text-secondary">AY: <strong class="text-primary">@record.AcademicYear</strong></div>
                                </div>
                                <span class="badge rounded-pill px-3 py-2 fw-bold align-self-center"
                                      style="background: rgba(34,197,94,0.15); color:#16a34a; font-size:0.75rem;">
                                    <i class="bi bi-patch-check-fill me-1"></i> Verified
                                </span>
                            </div>
                        </div>

                        <!-- Card Body: Data Fields -->
                        <div class="p-4">
                            <div class="row g-3">
                                @foreach (var entry in rowData)
                                {
                                    var cellVal = entry.Value ?? "";
                                    <div class="col-md-4 col-lg-3">
                                        <div class="smaller text-secondary text-uppercase fw-bold ls-1 mb-1">@(entry.Key ?? "–")</div>
                                        <div class="small fw-medium text-break">
                                            @if (cellVal.StartsWith("/uploads/"))
                                            {
                                                <a href="@cellVal" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill py-1 px-3 d-inline-flex align-items-center gap-1" style="font-size:0.7rem;">
                                                    <i class="bi bi-file-earmark-text"></i> View Doc
                                                </a>
                                            }
                                            else if (string.IsNullOrEmpty(cellVal))
                                            {
                                                <span class="text-secondary opacity-50">–</span>
                                            }
                                            else
                                            {
                                                <span title="@cellVal">@(cellVal.Length > 50 ? cellVal.Substring(0, 47) + "..." : cellVal)</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(record.Remarks) && record.Remarks != "Verified by HOD")
                            {
                                <div class="mt-3 pt-3 border-top border-secondary border-opacity-10">
                                    <span class="smaller text-secondary"><i class="bi bi-chat-left-quote me-1"></i> <strong>Remarks:</strong> @record.Remarks</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="glass-panel p-5 text-center mt-4">
            <div class="mb-4 opacity-25">
                <i class="bi bi-folder2-open" style="font-size: 3.5rem;"></i>
            </div>
            <h4 class="fw-bold text-secondary">No Finalized Records Found</h4>
            <p class="text-muted small">
                @if (!string.IsNullOrEmpty(tableFilter))
                {
                    <text>No approved records exist for this table. Try selecting a different table or clearing the filter.</text>
                }
                else
                {
                    <text>Faculty must submit data and you must approve it via the Approvals module before records appear here.</text>
                }
            </p>
            <a asp-action="Approvals" class="btn btn-premium-primary rounded-pill px-5 mt-2">
                <i class="bi bi-check-circle me-2"></i> Go to Approvals
            </a>
        </div>
    }
</div>
