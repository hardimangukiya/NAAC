<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NAAC Portal</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@700;800&display=swap" rel="stylesheet">
    
    <!-- Styles -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NAAC.styles.css" asp-append-version="true" />

    <!-- Theme Inline Script (Prevents Flickering) -->
    <script>
        (function () {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/naac-logo.png" alt="NAAC Logo" class="me-2" style="height: 60px; width: auto;" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-block';" />
                    <i class="bi bi-shield-check me-2" style="display: none;"></i> NAAC
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#roles">Portals</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <button id="theme-toggle" class="theme-toggle" title="Toggle Light/Dark Mode">
                                <i id="theme-icon" class="bi bi-sun"></i>
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>


    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-custom mt-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0">&copy; 2026 - NAAC Management System - Criteria 5 & 6</p>
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="me-3">Privacy Policy</a>
                    <a asp-area="" asp-controller="Home" asp-action="Support">Support</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme-toggle.js" asp-append-version="true"></script>
    <script src="~/js/support-logic.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Floating Help Button & Popup -->
    <button id="floatingHelpBtn" class="floating-help-btn" title="Need Help?">
        <i class="bi bi-question-lg"></i>
    </button>

    <div id="helpPopup" class="glass-panel help-popup shadow-lg">
        <div class="p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 text-primary fw-bold">Quick Support</h5>
                <button type="button" id="closeHelpPopup" class="btn-close" aria-label="Close" style="filter: var(--invert-filter);"></button>
            </div>
            <p class="text-secondary small mb-3">Facing issues? Quick links to help you out:</p>
            <div class="d-grid gap-2">
                <a asp-controller="Home" asp-action="Support" class="btn-portal py-2 small">
                    <i class="bi bi-book me-2"></i> View FAQs
                </a>
                <a href="mailto:naachod123@gmail.com" class="btn w-100 py-2 small text-secondary fw-medium" style="background: var(--secondary-color); border: 1px solid var(--glass-border); border-radius: 0.75rem;">
                    <i class="bi bi-envelope me-2"></i> Email Support
                </a>
            </div>
            <div class="mt-3 pt-3 border-top text-center">
                <p class="text-secondary smaller mb-0">Mon – Fri: 10AM – 5PM</p>
            </div>
        </div>
    </div>
</body>


</html>

