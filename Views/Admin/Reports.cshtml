@model IEnumerable<NAAC.Models.DataRecord>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Institutional Compliance Repository";
    var tables = Model != null ? Model.GroupBy(r => r.Table).ToList() : new List<IGrouping<NAAC.Models.NAACTable, NAAC.Models.DataRecord>>();
    var currentUserName = Context.Session.GetString("UserName") ?? "Admin";
    var currentDate = DateTime.Now.ToString("dd-MM-yyyy HH:mm:ss");
}

<div class="animate-fade-in px-2 px-md-0">
    <div class="mb-5 d-flex justify-content-between align-items-end">
        <div>
            <h2 class="fw-800 mb-0">Institutional Reports</h2>
            <p class="text-secondary small">Generate and export fully verified NAAC documentation across all departments.</p>
        </div>
        <div class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill smaller fw-bold ls-1 border border-primary border-opacity-10">CORE REGISTRY</div>
    </div>

    <div class="glass-panel p-3 px-4 mt-4 mb-3 border-0 shadow-sm d-flex align-items-center gap-3 flex-wrap"
         style="position: relative; z-index: 100;">
        
        <!-- 1. Table Selector -->
        <div class="dropdown">
            <button class="btn rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium"
                    type="button" id="reportTableDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false"
                    style="background: var(--card-bg); border: 1px solid var(--glass-border); color: var(--text-primary); min-width: 280px;">
                <i class="bi bi-funnel-fill text-primary"></i>
                <span id="selectedReportFilterText" style="color: var(--text-primary);">-- Select Institutional Table --</span>
                <i class="bi bi-chevron-down ms-auto small" style="color: var(--text-secondary);"></i>
            </button>
            <ul class="dropdown-menu report-dropdown-menu shadow border-0 mt-1 rounded-3 p-2"
                aria-labelledby="reportTableDropdownBtn"
                style="z-index:9999; min-width:380px; max-height:420px; overflow-y:auto;">
                <li>
                    <a class="dropdown-item rounded-2 mb-1 report-filter-item" href="#" data-value="">
                        <i class="bi bi-x-circle me-2 text-secondary"></i> Hide Dataset
                    </a>
                </li>
                <li><hr class="dropdown-divider my-1 opacity-25"></li>
                @foreach (var group in tables)
                {
                    <li>
                        <a class="dropdown-item rounded-2 mb-1 report-filter-item" href="#"
                           data-value="@group.Key.Id">
                            <span class="badge bg-primary bg-opacity-10 text-primary me-2 small">@group.Key.TableNumber</span>
                            <span class="text-main">@(group.Key.Name.Length > 40 ? group.Key.Name.Substring(0, 37) + "..." : group.Key.Name)</span>
                        </a>
                    </li>
                }
            </ul>
        </div>

        <!-- 2. Year & Faculty Filters -->
        <div class="d-flex align-items-center gap-2 flex-grow-1">
            <select id="ayFilterMaster" class="btn rounded-pill px-4 py-2 fw-medium text-start flex-grow-1 flex-md-grow-0 master-filter"
                    style="background: var(--card-bg); border: 1px solid var(--glass-border); color: var(--text-primary); min-width: 180px;">
                <option value="">-- All Academic Years --</option>
                @{
                    var currentYear = DateTime.Now.Month >= 6 ? DateTime.Now.Year : DateTime.Now.Year - 1;
                    for (int i = 0; i < 6; i++)
                    {
                        var start = currentYear - i;
                        var end = (start + 1) % 100;
                        var ay = $"{start}-{end:D2}";
                        <option value="@ay">@ay</option>
                    }
                }
            </select>

            <select id="facultyFilterMaster" class="btn rounded-pill px-4 py-2 fw-medium text-start flex-grow-1 flex-md-grow-0 master-filter"
                    style="background: var(--card-bg); border: 1px solid var(--glass-border); color: var(--text-primary); min-width: 220px;">
                <option value="">-- All Contributors --</option>
                @if (ViewBag.FacultyList != null)
                {
                    @foreach (var f in (IEnumerable<NAAC.Models.User>)ViewBag.FacultyList)
                    {
                        <option value="@f.FullName">@f.FullName</option>
                    }
                }
            </select>
        </div>
    </div>

    <!-- Container for dynamic tables -->
    <div id="tablesContainer">
        @foreach (var group in tables)
        {
            var firstRecord = group.First();
            var jsonColumns = new List<string>();
            try {
                foreach (var rec in group)
                {
                    var dataDict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(rec.JsonData ?? "{}");
                    if (dataDict != null)
                    {
                        foreach (var key in dataDict.Keys)
                        {
                            if (!jsonColumns.Contains(key))
                                jsonColumns.Add(key);
                        }
                    }
                }
            } catch { }

            <div id="table-wrapper-@group.Key.Id" class="d-none animate-fade-in table-wrapper">
                <div class="glass-panel p-0 overflow-hidden border-0 shadow-lg mb-5">
                    <div class="p-4 bg-primary bg-opacity-10 d-flex justify-content-between align-items-center border-bottom border-secondary border-opacity-10">
                        <div>
                            <span class="badge bg-primary text-white mb-2 py-2 px-3 rounded-pill shadow-sm">Table @group.Key.TableNumber</span>
                            <h5 class="fw-bold mb-0 text-main">@group.Key.Name</h5>
                        </div>
                        <div class="text-end text-secondary small d-none d-md-block">
                            <div><strong>Official:</strong> SYSTEM ADMIN</div>
                            <div><strong>Compiled on:</strong> @currentDate</div>
                        </div>
                    </div>
                    <div class="p-4 table-responsive">
                        <table id="export-table-@group.Key.Id" class="table-glass table-hover align-middle export-data-table w-100"
                               data-table-name="Institutional Table @group.Key.TableNumber: @group.Key.Name">
                            <thead class="text-nowrap">
                                <tr>
                                    <th>Academic Year</th>
                                    <th>Faculty Contributor</th>
                                    @foreach (var col in jsonColumns)
                                    {
                                        <th>@col</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var record in group)
                                {
                                    var rowData = new Dictionary<string, string>();
                                    try { rowData = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(record.JsonData ?? "{}") ?? new Dictionary<string, string>(); } catch { }

                                    <tr>
                                        <td><strong>@record.AcademicYear</strong></td>
                                        <td data-export="@(record.Faculty?.FullName ?? "Unknown")">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold dt-no-export" style="width: 25px; height: 25px; font-size: 0.7rem;" aria-hidden="true">
                                                    @((record.Faculty?.FullName ?? "U").Substring(0, 1).ToUpper())
                                                </div>
                                                <span class="small fw-medium">@(record.Faculty?.FullName ?? "Unknown")</span>
                                            </div>
                                        </td>
                                        @foreach (var col in jsonColumns)
                                        {
                                            var cellVal = rowData.ContainsKey(col) ? rowData[col] : "-";
                                            <td class="small text-break" style="min-width: 150px;">
                                                @if (!string.IsNullOrEmpty(cellVal) && (cellVal.StartsWith("/uploads/") || cellVal.StartsWith("http")))
                                                {
                                                    <a href="@cellVal" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill py-1 px-3 d-inline-flex align-items-center gap-2" style="font-size: 0.7rem; width: fit-content;">
                                                        <i class="bi bi-file-earmark-text"></i> View Doc
                                                    </a>
                                                    <span class="d-none">@cellVal</span>
                                                }
                                                else
                                                {
                                                    <span class="text-secondary opacity-50">@(string.IsNullOrEmpty(cellVal) ? "No File" : cellVal)</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
    
    @if (!tables.Any())
    {
        <div class="glass-panel p-5 text-center mt-4">
            <div class="opacity-25 mb-4"><i class="bi bi-file-earmark-x fs-1" style="font-size: 3rem !important;"></i></div>
            <h4 class="text-secondary fw-bold">No Verified Records Found</h4>
            <p class="text-muted">The system registry does not currently contain any approved accreditation datasets across institutional portfolios.</p>
        </div>
    }
</div>

<style>
    .fw-800 { font-weight: 800; }
    .ls-1 { letter-spacing: 1px; }
    .text-main { color: #1e293b; }
    [data-theme="dark"] .text-main { color: #f1f5f9; }
    
    .report-dropdown-menu {
        background: white !important;
        border: 1px solid rgba(0,0,0,0.1) !important;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
    }

    [data-theme="dark"] .report-dropdown-menu {
        background: #1e293b !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
    }

    .report-filter-item {
        color: #1e293b !important;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
    }

    [data-theme="dark"] .report-filter-item {
        color: #94a3b8 !important;
    }

    .report-filter-item .badge {
        background-color: rgba(79, 70, 229, 0.1) !important;
        color: #4f46e5 !important;
        font-weight: 700;
    }

    .report-filter-item:hover {
        background-color: var(--primary-color) !important;
        color: white !important;
    }

    .report-filter-item:hover .badge {
        background-color: rgba(255,255,255,0.2) !important;
        color: white !important;
    }

    .report-filter-item:hover .text-main {
        color: white !important;
    }

    .master-filter option {
        background: var(--card-bg);
        color: var(--text-primary);
    }

    .table-wrapper { margin-top: 2rem; }
    .dataTables_wrapper .dt-buttons { float: left; margin-bottom: 2rem; }
</style>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css" />
    
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

    <script>
        $(document).ready(function() {
            var currentUser = '@currentUserName';
            var currTime = '@currentDate';

            $('.export-data-table').each(function() {
                var tableName = $(this).attr('data-table-name');
                var exportMessage = 'Institutional Compliance Audit   |   Generated By: SYSTEM ADMIN   |   Verification: ' + currTime;

                var table = $(this).DataTable({
                    dom: '<"row mb-4 pt-3 align-items-center"<"col-12 d-flex justify-content-between align-items-center"B>>rt<"row mt-3"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            className: 'btn btn-success btn-sm px-4 me-2 rounded-pill shadow-sm py-2 text-white border-0',
                            text: '<i class="bi bi-file-earmark-excel-fill me-2"></i> Institutional Excel Export',
                            title: 'NAAC_Master_Report_' + tableName,
                            messageTop: exportMessage
                        },
                        {
                            extend: 'pdfHtml5',
                            className: 'btn btn-danger btn-sm px-4 rounded-pill shadow-sm py-2 text-white border-0',
                            text: '<i class="bi bi-file-earmark-pdf-fill me-2"></i> Institutional PDF Audit',
                            title: 'NAAC_Master_Report_' + tableName,
                            messageTop: exportMessage,
                            orientation: 'landscape',
                            pageSize: 'A4'
                        }
                    ],
                    pageLength: 25,
                    ordering: true,
                    language: { search: "", searchPlaceholder: "Global Search..." }
                });
            });

            $('.master-filter').on('change', function() {
                var ay = $('#ayFilterMaster').val();
                var fac = $('#facultyFilterMaster').val();
                $('.export-data-table').DataTable().columns(0).search(ay).columns(1).search(fac).draw();
            });

            $('.report-filter-item').on('click', function(e) {
                e.preventDefault();
                var selectedId = $(this).attr('data-value');
                var text = $(this).text();
                $("#selectedReportFilterText").text(selectedId === "" ? "-- Select Institutional Table --" : (text.length > 35 ? text.substring(0, 32) + "..." : text));
                $('.table-wrapper').addClass('d-none');
                if(selectedId) $('#table-wrapper-' + selectedId).removeClass('d-none');
            });
            
            $('.dataTables_filter input').addClass('form-control glass-input rounded-pill px-4 ms-2').css('width', '250px');
        });
    </script>
}
