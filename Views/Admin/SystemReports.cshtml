@model List<string>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "System Repository Manager";
}

<div class="animate-fade-in px-2 px-md-0">
    <!-- Executive Header with Global Snapshot -->
    <div class="glass-panel p-5 mb-5 shadow-lg border-0 position-relative overflow-hidden header-dynamic">
        <div class="position-absolute top-0 end-0 p-5 opacity-05">
            <i class="bi bi-terminal" style="font-size: 12rem; color: var(--primary-color);"></i>
        </div>
        
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="badge bg-primary bg-opacity-20 text-primary px-3 py-2 rounded-pill smaller fw-bold ls-1 border border-primary border-opacity-10">CORE DATABASE ACCESS</div>
                    <span class="text-success smaller fw-bold ls-1"><i class="bi bi-circle-fill smaller me-1 animate-pulse"></i> LIVE SESSION</span>
                </div>
                <h1 class="fw-800 mb-3 display-5 text-main">System Repository Manager</h1>
                <p class="text-secondary-dim lead mb-0">Direct low-level access to institutional datasets. perform structural audits, manual overrides, and framework optimization.</p>
            </div>
            <div class="col-lg-6">
                <!-- System Health Summary -->
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="glass-panel p-4 border-0 h-100 shadow-lg" style="background: rgba(var(--primary-rgb), 0.03);">
                            <div class="smaller fw-bold text-primary text-uppercase ls-1 mb-2">Framework Tables</div>
                            <div class="h3 fw-800 text-main mb-0">@Model.Count</div>
                            <div class="smaller text-secondary-dim mt-2">Active Structural Entities</div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="glass-panel p-4 border-0 h-100 shadow-lg" style="background: rgba(var(--primary-rgb), 0.03);">
                            <div class="smaller fw-bold text-success text-uppercase ls-1 mb-2">System Integrity</div>
                            <div class="h3 fw-800 text-main mb-0">100%</div>
                            <div class="smaller text-secondary-dim mt-2">Database Connection Active</div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="glass-panel p-4 border-0 shadow-lg d-flex align-items-center justify-content-between" style="background: rgba(var(--primary-rgb), 0.08); border: 1px dashed rgba(var(--primary-rgb), 0.2) !important;">
                            <div>
                                <div class="smaller fw-bold text-main text-uppercase ls-1 mb-1">Global Registry Export</div>
                                <div class="smaller text-secondary-dim">Consolidated manifest of all tables and raw records</div>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-action="BulkExport" asp-route-format="excel" class="btn btn-sm btn-success rounded-pill px-3 fw-bold border-0 bg-success bg-opacity-10 text-success">
                                    <i class="bi bi-file-earmark-spreadsheet me-1"></i> Bulk Excel
                                </a>
                                <a asp-action="BulkExport" asp-route-format="pdf" class="btn btn-sm btn-danger rounded-pill px-3 fw-bold border-0 bg-danger bg-opacity-10 text-danger">
                                    <i class="bi bi-file-earmark-pdf me-1"></i> Bulk PDF
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tables Grid -->
    <div class="mb-4 d-flex justify-content-between align-items-end">
        <div>
            <h4 class="fw-800 mb-1 text-main">Institutional Schema</h4>
            <p class="text-secondary small mb-0">Select a table to manage its raw records and structural integrity</p>
        </div>
        <div class="text-secondary smaller fw-bold ls-1">TOTAL TABLES: @Model.Count</div>
    </div>

    <div class="row g-4 mb-5">
        @foreach (var table in Model)
        {
            <div class="col-xl-3 col-lg-4 col-sm-6">
                <a asp-action="TableManager" asp-route-tableName="@table" class="text-decoration-none">
                    <div class="glass-panel p-4 h-100 border-0 shadow-sm hover-scale-sm d-flex align-items-center gap-3">
                        <div class="icon-sq bg-secondary bg-opacity-10 text-secondary rounded-3" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-table fs-5"></i>
                        </div>
                        <div class="overflow-hidden">
                            <div class="fw-800 text-main text-truncate">@table</div>
                            <div class="smaller text-secondary-dim">Audit & Manage Records</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-secondary opacity-50"></i>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .ls-1 { letter-spacing: 1px; }
    .text-main { color: var(--text-primary); }
    .text-secondary-dim { color: var(--text-secondary); opacity: 0.7; }
    [data-theme="dark"] .text-main { color: #f1f5f9; }
    .opacity-05 { opacity: 0.05; }
    
    .hover-scale-sm { transition: transform 0.3s ease, background 0.3s ease; }
    .hover-scale-sm:hover { transform: translateY(-3px); background: rgba(255,255,255,0.05) !important; cursor: pointer; }
    
    .cursor-pointer { cursor: pointer; }
    .animate-pulse { animation: pulse 2s infinite; }
    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }

    .header-dynamic {
        background: linear-gradient(135deg, rgba(var(--primary-rgb), 0.05) 0%, rgba(var(--primary-rgb), 0.01) 100%);
        border: 1px solid rgba(var(--primary-rgb), 0.1) !important;
    }
    
    [data-theme="dark"] .header-dynamic {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        border: none !important;
    }
</style>

@section Scripts {
    <script>
    </script>
}
