@model NAAC.Models.SystemSetting
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Institutional Branding";
}

<div class="animate-fade-in px-2 px-md-0">
    <div class="mb-5 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-800 mb-0 text-main">System Settings</h2>
            <p class="text-secondary small">Manage the global identity and visual branding of the NAAC portal.</p>
        </div>
        <div class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill smaller fw-bold ls-1 border border-primary border-opacity-10">IDENTITY CONTROL</div>
    </div>

    <div class="row g-5">
        <div class="col-lg-8">
            <div class="glass-panel p-5 shadow-lg border-0 h-100 overflow-hidden position-relative">
                <!-- Branding Form -->
                <form id="brandingForm" enctype="multipart/form-data">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="smaller fw-bold text-primary text-uppercase ls-1 mb-2">Platform Name</label>
                            <input type="text" name="systemName" value="@Model.SystemName" class="form-control glass-input py-3 px-4 rounded-3 text-main" required placeholder="e.g. NAAC Compliance Portal" />
                            <div class="smaller text-secondary-dim mt-2">This name appears in the browser tab and sidebar branding.</div>
                        </div>

                        <div class="col-12">
                            <label class="smaller fw-bold text-primary text-uppercase ls-1 mb-2">Official Institution Name</label>
                            <input type="text" name="institutionName" value="@Model.InstitutionName" class="form-control glass-input py-3 px-4 rounded-3 text-main" required placeholder="e.g. National Assessment and Accreditation Council" />
                            <div class="smaller text-secondary-dim mt-2">The full official name for institutional documentation and reports.</div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn btn-portal btn-lg rounded-pill px-5 fw-bold shadow-lg">
                                Update Platform Identity <i class="bi bi-shield-check ms-2"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="glass-panel p-5 shadow-lg border-0 h-100 text-center">
                <label class="smaller fw-bold text-primary text-uppercase ls-1 mb-4 d-block">Visual Signature (Logo)</label>
                
                <div class="logo-preview-container mb-4 mx-auto glass-panel p-4 d-flex align-items-center justify-content-center overflow-hidden" style="width: 180px; height: 180px; background: rgba(var(--primary-rgb), 0.05); border-radius: 50%;">
                    <img id="logoPreview" src="@Model.SystemLogo" alt="System Logo" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                </div>

                <div class="mb-4">
                    <button class="btn btn-sm btn-outline-primary rounded-pill px-4 fw-bold" onclick="document.getElementById('logoInput').click()">
                        <i class="bi bi-camera-fill me-2"></i> Change Logo
                    </button>
                    <input type="file" id="logoInput" name="logoFile" class="d-none" accept="image/*" onchange="previewLogo(this)" />
                </div>

                <div class="p-3 rounded-4 mt-4 d-flex gap-3 align-items-start text-start" 
                     style="background: rgba(var(--primary-rgb), 0.05); border: 1px solid rgba(var(--primary-rgb), 0.1);">
                    <i class="bi bi-info-circle-fill text-primary mt-1"></i>
                    <div>
                        <div class="smaller fw-bold text-main mb-1">IMAGE GUIDELINES</div>
                        <div class="smaller text-secondary-dim" style="line-height: 1.4;">
                            Recommended: <strong>Transparent PNG</strong> (200&times;200px) for optimal blending. Scale is managed automatically by the registry.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .ls-1 { letter-spacing: 1px; }
    .text-main { color: var(--text-primary); }
    .text-secondary-dim { color: var(--text-secondary); opacity: 0.7; }
    [data-theme="dark"] .text-main { color: #f1f5f9; }
    
    .logo-preview-container {
        border: 2px dashed rgba(var(--primary-rgb), 0.2);
        transition: all 0.3s ease;
    }
    .logo-preview-container:hover {
        border-color: var(--primary-color);
        background: rgba(var(--primary-rgb), 0.1) !important;
    }

    .glass-input {
        background: rgba(var(--accent-rgb), 0.03) !important;
        border: 1px solid var(--glass-border) !important;
        color: var(--text-primary) !important;
    }
    .glass-input:focus {
        background: rgba(var(--accent-rgb), 0.06) !important;
        border-color: var(--primary-color) !important;
        box-shadow: 0 0 15px rgba(var(--primary-rgb), 0.1) !important;
    }
</style>

@section Scripts {
    <script>
        function previewLogo(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#logoPreview').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        $('#brandingForm').on('submit', async function(e) {
            e.preventDefault();
            
            const formData = new FormData(this);
            const logoFile = document.getElementById('logoInput').files[0];
            if (logoFile) {
                formData.append('logoFile', logoFile);
            }

            try {
                const response = await fetch('/Admin/UpdateSystemSettings', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();
                
                if (result.success) {
                    alert('Institutional identity updated successfully. Reloading platform...');
                    location.reload();
                } else {
                    alert('Update failed: ' + result.message);
                }
            } catch (error) {
                alert('An error occurred during update.');
            }
        });
    </script>
}
