@model NAAC.Models.User
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Security Profile";
}

<div class="animate-fade-in px-2 px-md-0">
    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-5">
        <a asp-action="ManageUsers" class="btn btn-icon glass-panel rounded-circle text-secondary">
            <i class="bi bi-chevron-left"></i>
        </a>
        <div>
            <h2 class="fw-800 mb-0">Security Profile</h2>
            <p class="text-secondary small mb-0">Auditing and managing @Model.FullName's system access</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-panel p-5 shadow-lg border-0">
                <form id="editUserForm">
                    <input type="hidden" id="userId" value="@Model.Id" />
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label smaller fw-bold text-secondary text-uppercase ls-1">Full Name</label>
                            <input type="text" id="fullName" class="form-control-custom" value="@Model.FullName" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label smaller fw-bold text-secondary text-uppercase ls-1">Email (Read Only)</label>
                            <input type="email" class="form-control-custom opacity-50" value="@Model.Email" readonly />
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label smaller fw-bold text-secondary text-uppercase ls-1">System Role</label>
                            <select id="userRole" class="form-select-custom">
                                <option value="Faculty" selected="@(Model.Role == "Faculty")">Faculty Staff</option>
                                <option value="HOD" selected="@(Model.Role == "HOD")">Department HOD</option>
                                <option value="Coordinator" selected="@(Model.Role == "Coordinator")">NAAC Coordinator</option>
                                <option value="Admin" selected="@(Model.Role == "Admin")">System Administrator</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label smaller fw-bold text-secondary text-uppercase ls-1">Institutional Entity</label>
                            <input type="text" id="collegeName" class="form-control-custom" value="@Model.CollegeName" required />
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top border-secondary border-opacity-10 d-flex gap-3">
                        <button type="submit" class="btn btn-portal px-5 rounded-pill py-3 fw-bold">Save Security Profile</button>
                        <button type="button" class="btn btn-outline-secondary px-4 rounded-pill py-3 border-0 small fw-bold ls-1">RESET PASSWORD</button>
                    </div>
                </form>
            </div>
            
            <div id="statusMessage" class="mt-4 p-3 rounded-4 d-none"></div>
        </div>

        <div class="col-lg-4">
            <div class="glass-panel p-5 h-100 shadow-sm border-0">
                <h5 class="fw-800 mb-4">Account Metadata</h5>
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                        <div>
                            <div class="smaller text-secondary fw-bold text-uppercase ls-1">Registered On</div>
                            <div class="fw-bold text-main">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <div>
                            <div class="smaller text-secondary fw-bold text-uppercase ls-1">Account Status</div>
                            <div class="fw-bold text-success">Active & Verified</div>
                        </div>
                    </div>

                    <div class="mt-4 p-4 rounded-4 bg-danger bg-opacity-5 border border-danger border-opacity-10">
                        <h6 class="text-danger fw-bold mb-2">Danger Zone</h6>
                        <p class="smaller text-secondary mb-3">Removing this user will permanently delete all associated session data.</p>
                        <button class="btn btn-sm btn-outline-danger w-100 rounded-pill border-0" onclick="deleteUser(@Model.Id, '@Model.FullName')">
                            Remove Account
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-800 { font-weight: 800; }
    .ls-1 { letter-spacing: 1px; }
    .text-main { color: var(--text-primary); }
    [data-theme="dark"] .text-main { color: #f1f5f9; }
    
    .icon-circle {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

@section Scripts {
    <script>
        document.getElementById('editUserForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const statusDiv = document.getElementById('statusMessage');
            
            const formData = new URLSearchParams();
            formData.append('id', document.getElementById('userId').value);
            formData.append('role', document.getElementById('userRole').value);
            formData.append('fullName', document.getElementById('fullName').value);
            formData.append('collegeName', document.getElementById('collegeName').value);

            try {
                const response = await fetch('/Admin/UpdateUserSecurity', {
                    method: 'POST',
                    body: formData,
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
                });
                
                const result = await response.json();
                statusDiv.className = `mt-4 p-3 rounded-4 ${result.success ? 'bg-success bg-opacity-10 text-success' : 'bg-danger bg-opacity-10 text-danger'}`;
                statusDiv.textContent = result.message;
                statusDiv.classList.remove('d-none');
                
                if (result.success) {
                    setTimeout(() => statusDiv.classList.add('d-none'), 3000);
                }
            } catch (error) {
                console.error('Update failed', error);
            }
        });

        async function deleteUser(id, name) {
            if (confirm(`CRITICAL: Are you sure you want to remove ${name}?`)) {
                const response = await fetch(`/Admin/DeleteUser/${id}`, { method: 'POST' });
                const result = await response.json();
                if (result.success) window.location.href = '/Admin/ManageUsers';
            }
        }
    </script>
}
